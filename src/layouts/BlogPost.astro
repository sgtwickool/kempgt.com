---
import BaseLayout from "./BaseLayout.astro";

export interface Props {
  title: string;
  date: Date;
  author: string;
  tags: string[];
  summary: string;
  math: boolean;
}

const { title, date, author, tags, summary, math } = Astro.props;

const formattedDate = date.toLocaleDateString("en-GB", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
const isoDate = date.toISOString().split("T")[0];
---

<BaseLayout title={`${title} | Greg Kemp`} description={summary} math={math}>
  <article class="blog-post">
    <div class="container">
      <div class="blog-container mx-auto">
        <a href="/blog" class="blog-back">&larr; All posts</a>
        <header class="blog-post-header" data-aos="fade-up">
          <p class="blog-post-meta">
            <time datetime={isoDate}>{formattedDate}</time>
            <span class="mx-1">·</span>
            <span>{author}</span>
          </p>
          <h1 class="blog-post-title">{title}</h1>
          {
            tags.length > 0 && (
              <div class="blog-tags">
                {tags.map((tag) => (
                  <span class="blog-tag">{tag}</span>
                ))}
              </div>
            )
          }
        </header>
        <div class="blog-content" data-aos="fade-up" data-aos-delay="100">
          <slot />
        </div>
      </div>
    </div>
  </article>
</BaseLayout>
