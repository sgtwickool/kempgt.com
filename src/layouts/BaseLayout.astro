---
export interface Props {
  title?: string;
  description?: string;
  /** Set true on pages that render maths so KaTeX CSS is loaded. */
  math?: boolean;
}

const {
  title = "Greg Kemp",
  description = "Greg Kemp is a senior full-stack engineer who builds complete products end-to-end. 10+ years shipping production software for global brands.",
  math = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Inter for UI (matches the rest of the site); Newsreader for long-form reading. -->
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
    />
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet" />
    {
      math && (
        <link
          rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css"
          integrity="sha384-nB0miv6/jRmo5UMMR1wu3Gz6NLsoTkbqJghGIsx//Rlm+ZU03BU6SQNC66uf4l5+"
          crossorigin="anonymous"
        />
      )
    }
    <link rel="stylesheet" href="/assets/css/style.css" />
    <link rel="stylesheet" href="/assets/css/contact-form.css" />
    <link rel="icon" type="image/png" href="/assets/favicon.ico" />
  </head>
  <body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg">
      <div class="container">
        <a class="navbar-brand" href="/">Greg Kemp</a>
        <button
          class="navbar-toggler"
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#navbarNav"
        >
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav ms-auto">
            <li class="nav-item">
              <a class="nav-link" href="/#about">About</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/#experience">Experience</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/#projects">Projects</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/blog">Blog</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/#contact">Contact</a>
            </li>
            <li class="nav-item">
              <a
                class="btn btn-outline-primary ms-lg-3"
                href="/assets/Greg_Kemp_CV.pdf"
                download>Download CV</a
              >
            </li>
            <li class="nav-item d-flex align-items-center ms-lg-3">
              <button
                id="darkModeToggle"
                class="btn btn-sm btn-outline-secondary"
                aria-label="Toggle dark mode"
              >
                <span id="darkModeIcon" class="bi bi-moon"></span>
              </button>
            </li>
          </ul>
        </div>
      </div>
    </nav>

    <slot />

    <footer class="footer">
      <div class="container">
        <div class="mb-3">
          <a
            href="https://github.com/sgtwickool"
            target="_blank"
            rel="noopener"
            class="footer-icon-link me-3"
            aria-label="GitHub"
          >
            <i class="bi bi-github"></i>
          </a>
          <a
            href="https://www.linkedin.com/in/kempgt/"
            target="_blank"
            rel="noopener"
            class="footer-icon-link me-3"
            aria-label="LinkedIn"
          >
            <i class="bi bi-linkedin"></i>
          </a>
        </div>
        <div class="mb-2">&copy; 2026 Greg Kemp</div>
        <a
          href="#"
          class="footer-backtotop d-inline-block mt-1"
          aria-label="Back to top"
        >
          <i class="bi bi-arrow-up-circle"></i> Back to top
        </a>
      </div>
    </footer>

    <script
      is:inline
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
    ></script>
    <script is:inline src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script is:inline src="/assets/js/contact-form.js"></script>
    <script is:inline src="/assets/js/main.js"></script>
  </body>
</html>
